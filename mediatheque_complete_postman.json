  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123!\",\n  \"locale\": \"ar\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"esra.ones@beestory.tn\",\n  \"password\": \"12345678\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Contents & Media",
      "item": [
        {
          "name": "List Contents",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.data && json.data.contents && json.data.contents.length > 0) {",
                  "    pm.collectionVariables.set('contentId', json.data.contents[0]._id);",
                  "    if (json.data.contents[0].contentUrl) {",
                  "      var parts = json.data.contents[0].contentUrl.split('/');",
                  "      pm.collectionVariables.set('fileId', parts[parts.length - 1]);",
                  "    }",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contents?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contents"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Content",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/contents/{{contentId}}"
          }
        },
        {
          "name": "Stream Media",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/media/{{fileId}}",
            "header": [
              {
                "key": "Range",
                "value": "bytes=0-1024"
              }
            ]
          }
        }
      ]
    },
